DATABASE_URL="file:./dev.db"
APP_SECRET="replace-with-at-least-32-random-characters"
CORS_ORIGINS=""
COOKIE_SECURE=""

# ===== 注册控制 =====
# 是否允许普通用户注册（true/false）
ALLOW_USER_REGISTRATION=true

# 注册时是否需要兑换码（true/false）
REQUIRE_INVITE_CODE_ON_REGISTER=false

# ===== 用户相关 =====
# 新用户初始积分
DEFAULT_USER_CREDITS=1

# 每个用户最多保存会话数
MAX_CONVERSATIONS_PER_USER=50

# 每个会话最多保存消息数
MAX_MESSAGES_PER_CONVERSATION=100

# 单次对话最多携带历史消息数
MAX_CONTEXT_MESSAGES=20

# 单条消息内容最大字符数（服务端校验）
MAX_MESSAGE_CHARS=100000

# 单次请求携带上下文的总字符数上限
MAX_CONTEXT_CHARS=200000

# 单次请求上下文中最多包含的图片数量
MAX_CONTEXT_IMAGES=4

# ===== 兑换码相关 =====
# 兑换码长度
REDEEM_CODE_LENGTH=8

# ===== 积分相关 =====
# 每次聊天消耗积分
CREDIT_PER_CHAT_MESSAGE=1

# 每次图片生成消耗积分
CREDIT_PER_IMAGE_GENERATION=5
